@model AdminItemsPageViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Items";
    ViewData["AdminDateRange"] = Model.DateRangeLabel;
    ViewData["AdminSection"] = "Items";
}

<section class="admin-account-summary-grid admin-item-summary-grid">
    @foreach (var item in Model.SummaryItems)
    {
        <article class="admin-card admin-account-summary-card admin-item-summary-card @($"is-{item.AccentKey}")">
            <small>@item.Label</small>
            <strong>@item.Value</strong>
            <span>@item.Detail</span>
        </article>
    }
</section>

<datalist id="adminItemCategories">
    @foreach (var category in Model.Categories)
    {
        <option value="@category"></option>
    }
</datalist>

<section class="admin-items-page" data-admin-items data-active-modal="@Model.ActiveModal">
    <article class="admin-card admin-items-toolbar">
        <div class="admin-items-toolbar-head">
            <div>
                <p class="admin-page-kicker">Items</p>
                <h2>Inventory Catalog</h2>
                <span>ค้นหา จัดเรียง และจัดการสินค้าจากแถบเดียว</span>
            </div>
            <span class="admin-items-toolbar-count" data-items-results-label>@Model.Items.Count รายการ</span>
        </div>

        <div class="admin-items-toolbar-controls">
            <label class="admin-toolbar-field admin-toolbar-field-search">
                <span>Search</span>
                <input type="search"
                       class="form-control bakery-field"
                       placeholder="ค้นหาชื่อสินค้า, SKU หรือหมวด"
                       data-items-search />
            </label>

            <label class="admin-toolbar-field">
                <span>Category</span>
                <select class="form-select bakery-field" data-items-category-filter>
                    <option value="all">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </label>

            <label class="admin-toolbar-field">
                <span>Sort</span>
                <select class="form-select bakery-field" data-items-sort>
                    <option value="name-asc">Name A-Z</option>
                    <option value="name-desc">Name Z-A</option>
                    <option value="price-desc">Price High-Low</option>
                    <option value="price-asc">Price Low-High</option>
                    <option value="stock-desc">Stock High-Low</option>
                    <option value="stock-asc">Stock Low-High</option>
                    <option value="updated-desc">Updated ล่าสุด</option>
                </select>
            </label>

            <div class="admin-items-toolbar-actions">
                <button type="button"
                        class="admin-secondary-button"
                        data-open-category-modal
                        data-category-target=""
                        data-return-modal-id="">
                    Add Category
                </button>
                <button type="button" class="admin-primary-button" data-bs-toggle="modal" data-bs-target="#addItemModal">
                    Add Item
                </button>
            </div>
        </div>
    </article>

    <div class="admin-empty-state d-none" data-items-empty-state>
        ไม่พบสินค้าที่ตรงกับเงื่อนไขที่เลือก
    </div>

    <div class="admin-items-card-grid" data-items-grid>
        @foreach (var item in Model.Items)
        {
            <article class="admin-card admin-item-card"
                     data-item-card
                     data-item-id="@item.ItemId"
                     data-name="@item.Name"
                     data-category="@item.Category"
                     data-sku="@item.Sku"
                     data-price="@item.PriceAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                     data-stock="@item.StockQuantity"
                     data-updated-at="@item.UpdatedAtSort">
                <div class="admin-item-card-media">
                    <img src="@Url.Content(item.ImagePath)"
                         alt="@item.Name"
                         class="admin-item-card-image"
                         onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                </div>

                <div class="admin-item-card-body">
                    <div class="admin-item-card-head">
                        <div>
                            <p class="admin-item-card-code">@item.ItemCode</p>
                            <h3>@item.Name</h3>
                        </div>
                        <span class="admin-status-badge @($"is-{item.StatusKey}")" data-stock-status-badge>@item.StatusLabel</span>
                    </div>

                    <p class="admin-item-card-caption">@item.Tagline</p>

                    <div class="admin-item-meta-row">
                        <span class="admin-item-meta-chip">@item.Category</span>
                        <span class="admin-item-meta-chip">@item.PriceLabel</span>
                        <span class="admin-item-meta-chip">SKU @item.Sku</span>
                    </div>

                    <div class="admin-item-stock-row">
                        <div class="admin-item-stock-copy">
                            <small>Stock</small>
                            <strong data-stock-count>@item.StockQuantity</strong>
                            <span>Reorder when below @item.ReorderLevel</span>
                        </div>

                        <div class="admin-item-stock-actions">
                            <form asp-action="AdjustItemStock" method="post" class="admin-stock-adjust-form" data-stock-adjust-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.ItemId" />
                                <input type="hidden" name="quantityDirection" value="1" data-stock-direction-input />
                                <label class="admin-stock-amount-field">
                                    <span>จำนวนที่จะปรับ</span>
                                    <input type="number"
                                           name="quantityAmount"
                                           value="1"
                                           min="1"
                                           step="1"
                                           inputmode="numeric"
                                           class="admin-stock-amount-input"
                                           data-stock-amount />
                                </label>

                                <div class="admin-stock-button-group">
                                    <button type="button"
                                            class="admin-stock-circle-button is-minus"
                                            data-stock-direction="-1"
                                            @(item.StockQuantity == 0 ? "disabled" : null)>-</button>
                                    <button type="button"
                                            class="admin-stock-circle-button is-plus"
                                            data-stock-direction="1">+</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="admin-item-card-footer">
                        <span class="admin-item-updated" data-stock-updated>Updated @item.UpdatedAtLabel</span>

                        <button type="button"
                                class="admin-secondary-button admin-edit-item-button"
                                data-bs-toggle="modal"
                                data-bs-target="#editItemModal"
                                data-item-id="@item.ItemId"
                                data-item-code="@item.ItemCode"
                                data-name="@item.Name"
                                data-category="@item.Category"
                                data-sku="@item.Sku"
                                data-price="@item.PriceLabel.Replace(" ฿", string.Empty)"
                                data-stock-quantity="@item.StockQuantity"
                                data-reorder-level="@item.ReorderLevel"
                                data-tagline="@item.Tagline"
                                data-notes="@item.Notes"
                                data-image-path="@item.ImagePath"
                                data-is-published="@item.IsPublished.ToString().ToLowerInvariant()">
                            Edit
                        </button>
                    </div>
                </div>
            </article>
        }
    </div>
</section>

<div class="modal fade admin-modal" id="addItemModal" tabindex="-1" aria-labelledby="addItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Create Item</p>
                    <h2 class="modal-title" id="addItemModalLabel">Add New Item</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="AddItem" method="post" enctype="multipart/form-data" class="admin-item-form">
                    @Html.AntiForgeryToken()

                    <div class="admin-readonly-note">
                        Item ID จะถูกสร้างอัตโนมัติหลังบันทึก
                    </div>

                    <div class="admin-form-grid">
                        <div class="admin-form-span-full">
                            <label asp-for="AddForm.Name" class="form-label">Item name</label>
                            <input asp-for="AddForm.Name" class="form-control bakery-field" placeholder="Rose Macaron Box" />
                            <span asp-validation-for="AddForm.Name" class="text-danger small"></span>
                        </div>

                        <div>
                            <div class="admin-inline-label-row">
                                <label asp-for="AddForm.Category" class="form-label">หมวดสินค้า</label>
                                <button type="button"
                                        class="admin-inline-link-button"
                                        data-open-category-modal
                                        data-category-target="AddForm_Category"
                                        data-return-modal-id="addItemModal">
                                    เพิ่มหมวด
                                </button>
                            </div>
                            <select asp-for="AddForm.Category" class="form-select bakery-field admin-category-select" data-category-select>
                                <option value="">เลือกหมวดสินค้า</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            </select>
                            <span class="admin-field-note">เลือกหมวดที่มีอยู่ หรือกด เพิ่มหมวด เพื่อสร้างหมวดใหม่</span>
                            <span asp-validation-for="AddForm.Category" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Sku" class="form-label">รหัสสินค้า (SKU)</label>
                            <input asp-for="AddForm.Sku" class="form-control bakery-field" placeholder="เช่น BRD-CRO-001" />
                            <span class="admin-field-note">ใช้รหัสสั้น จำง่าย และไม่ซ้ำ เช่น หมวด-ชื่อสินค้า-ลำดับ</span>
                            <span asp-validation-for="AddForm.Sku" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Price" class="form-label">Price</label>
                            <input asp-for="AddForm.Price" class="form-control bakery-field" type="number" min="1" step="0.01" />
                            <span asp-validation-for="AddForm.Price" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.StockQuantity" class="form-label">Opening stock</label>
                            <input asp-for="AddForm.StockQuantity" class="form-control bakery-field" type="number" min="0" step="1" />
                            <span asp-validation-for="AddForm.StockQuantity" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.ReorderLevel" class="form-label">Reorder level</label>
                            <input asp-for="AddForm.ReorderLevel" class="form-control bakery-field" type="number" min="0" step="1" />
                            <span asp-validation-for="AddForm.ReorderLevel" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full admin-image-upload-field" data-item-image-picker>
                            <label asp-for="AddForm.ImageFile" class="form-label">รูปสินค้า</label>
                            <input asp-for="AddForm.ImageFile"
                                   class="form-control bakery-field"
                                   type="file"
                                   accept=".jpg,.jpeg,.png,.webp,.gif,image/jpeg,image/png,image/webp,image/gif"
                                   data-item-image-upload />
                            <input asp-for="AddForm.ImagePath" type="hidden" data-item-image-path />

                            <div class="admin-image-preview-row">
                                <div class="admin-image-preview-card">
                                    <img src="@Url.Content(Model.AddForm.ImagePath)"
                                         alt="ตัวอย่างรูปสินค้า"
                                         data-item-image-preview
                                         onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                                </div>
                                <div>
                                    <strong>อัปโหลดรูปใหม่ หรือเลือกรูปที่มีอยู่ด้านล่าง</strong>
                                    <small data-item-image-label>@Model.AddForm.ImagePath</small>
                                </div>
                            </div>

                            <div class="admin-image-option-strip" data-item-image-strip>
                                @foreach (var imagePath in Model.ImageOptions)
                                {
                                    var isSelected = string.Equals(Model.AddForm.ImagePath, imagePath, StringComparison.OrdinalIgnoreCase);
                                    <button type="button"
                                            class="admin-image-option-button @(isSelected ? "is-selected" : string.Empty)"
                                            data-item-image-option="@imagePath"
                                            aria-pressed="@(isSelected ? "true" : "false")">
                                        <img src="@Url.Content(imagePath)"
                                             alt="@imagePath"
                                             onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                                        <span>@System.IO.Path.GetFileNameWithoutExtension(imagePath)</span>
                                    </button>
                                }
                            </div>

                            <span class="admin-field-note">รองรับไฟล์ JPG, PNG, WEBP หรือ GIF ขนาดไม่เกิน 5MB</span>
                            <span asp-validation-for="AddForm.ImageFile" class="text-danger small"></span>
                            <span asp-validation-for="AddForm.ImagePath" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="AddForm.Tagline" class="form-label">Short description</label>
                            <input asp-for="AddForm.Tagline" class="form-control bakery-field" placeholder="Best seller for gift boxes" />
                            <span asp-validation-for="AddForm.Tagline" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="AddForm.Notes" class="form-label">Internal notes</label>
                            <textarea asp-for="AddForm.Notes" class="form-control bakery-field bakery-field-area admin-field-area" placeholder="Internal note for team"></textarea>
                            <span asp-validation-for="AddForm.Notes" class="text-danger small"></span>
                        </div>
                    </div>

                    <label class="form-check form-switch admin-switch-field">
                        <input asp-for="AddForm.IsPublished" class="form-check-input" />
                        <span class="form-check-label">Publish item immediately</span>
                    </label>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button">Create Item</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade admin-modal" id="editItemModal" tabindex="-1" aria-labelledby="editItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Edit Item</p>
                    <h2 class="modal-title" id="editItemModalLabel">Update Item Details</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="UpdateItem" method="post" enctype="multipart/form-data" class="admin-item-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="EditForm.ItemId" type="hidden" />
                    <input asp-for="EditForm.StockQuantity" type="hidden" />

                    <div class="admin-form-grid">
                        <div>
                            <label asp-for="EditForm.ItemCode" class="form-label">Item ID</label>
                            <input asp-for="EditForm.ItemCode" class="form-control bakery-field admin-readonly-field" readonly />
                        </div>

                        <div>
                            <label class="form-label">Current stock</label>
                            <input type="text" id="EditStockDisplay" class="form-control bakery-field admin-readonly-field" readonly value="@(Model.EditForm.StockQuantity > 0 ? $"{Model.EditForm.StockQuantity} units" : string.Empty)" />
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.Name" class="form-label">Item name</label>
                            <input asp-for="EditForm.Name" class="form-control bakery-field" />
                            <span asp-validation-for="EditForm.Name" class="text-danger small"></span>
                        </div>

                        <div>
                            <div class="admin-inline-label-row">
                                <label asp-for="EditForm.Category" class="form-label">หมวดสินค้า</label>
                                <button type="button"
                                        class="admin-inline-link-button"
                                        data-open-category-modal
                                        data-category-target="EditForm_Category"
                                        data-return-modal-id="editItemModal">
                                    เพิ่มหมวด
                                </button>
                            </div>
                            <select asp-for="EditForm.Category" class="form-select bakery-field admin-category-select" data-category-select>
                                <option value="">เลือกหมวดสินค้า</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            </select>
                            <span class="admin-field-note">เลือกหมวดที่มีอยู่ หรือกด เพิ่มหมวด เพื่อสร้างหมวดใหม่</span>
                            <span asp-validation-for="EditForm.Category" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="EditForm.Sku" class="form-label">รหัสสินค้า (SKU)</label>
                            <input asp-for="EditForm.Sku" class="form-control bakery-field" placeholder="เช่น BRD-CRO-001" />
                            <span class="admin-field-note">ใช้รหัสสั้น จำง่าย และไม่ซ้ำ เช่น หมวด-ชื่อสินค้า-ลำดับ</span>
                            <span asp-validation-for="EditForm.Sku" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="EditForm.Price" class="form-label">Price</label>
                            <input asp-for="EditForm.Price" class="form-control bakery-field" type="number" min="1" step="0.01" />
                            <span asp-validation-for="EditForm.Price" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="EditForm.ReorderLevel" class="form-label">Reorder level</label>
                            <input asp-for="EditForm.ReorderLevel" class="form-control bakery-field" type="number" min="0" step="1" />
                            <span asp-validation-for="EditForm.ReorderLevel" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full admin-image-upload-field" data-item-image-picker>
                            <label asp-for="EditForm.ImageFile" class="form-label">รูปสินค้า</label>
                            <input asp-for="EditForm.ImageFile"
                                   class="form-control bakery-field"
                                   type="file"
                                   accept=".jpg,.jpeg,.png,.webp,.gif,image/jpeg,image/png,image/webp,image/gif"
                                   data-item-image-upload />
                            <input asp-for="EditForm.ImagePath" type="hidden" data-item-image-path />

                            <div class="admin-image-preview-row">
                                <div class="admin-image-preview-card">
                                    <img src="@Url.Content(Model.EditForm.ImagePath)"
                                         alt="ตัวอย่างรูปสินค้า"
                                         data-item-image-preview
                                         onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                                </div>
                                <div>
                                    <strong>อัปโหลดรูปใหม่ หรือเลือกรูปที่มีอยู่ด้านล่าง</strong>
                                    <small data-item-image-label>@Model.EditForm.ImagePath</small>
                                </div>
                            </div>

                            <div class="admin-image-option-strip" data-item-image-strip>
                                @foreach (var imagePath in Model.ImageOptions)
                                {
                                    var isSelected = string.Equals(Model.EditForm.ImagePath, imagePath, StringComparison.OrdinalIgnoreCase);
                                    <button type="button"
                                            class="admin-image-option-button @(isSelected ? "is-selected" : string.Empty)"
                                            data-item-image-option="@imagePath"
                                            aria-pressed="@(isSelected ? "true" : "false")">
                                        <img src="@Url.Content(imagePath)"
                                             alt="@imagePath"
                                             onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                                        <span>@System.IO.Path.GetFileNameWithoutExtension(imagePath)</span>
                                    </button>
                                }
                            </div>

                            <span class="admin-field-note">อัปโหลดเฉพาะเมื่อต้องการเปลี่ยนรูป ถ้าไม่เลือกไฟล์ใหม่ระบบจะใช้รูปเดิม</span>
                            <span asp-validation-for="EditForm.ImageFile" class="text-danger small"></span>
                            <span asp-validation-for="EditForm.ImagePath" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.Tagline" class="form-label">Short description</label>
                            <input asp-for="EditForm.Tagline" class="form-control bakery-field" />
                            <span asp-validation-for="EditForm.Tagline" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.Notes" class="form-label">Internal notes</label>
                            <textarea asp-for="EditForm.Notes" class="form-control bakery-field bakery-field-area admin-field-area"></textarea>
                            <span asp-validation-for="EditForm.Notes" class="text-danger small"></span>
                        </div>
                    </div>

                    <label class="form-check form-switch admin-switch-field">
                        <input asp-for="EditForm.IsPublished" class="form-check-input" />
                        <span class="form-check-label">Published in storefront</span>
                    </label>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade admin-modal" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Create Category</p>
                    <h2 class="modal-title" id="addCategoryModalLabel">Add New Category</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="AddCategory" method="post" class="admin-item-form" data-add-category-form>
                    @Html.AntiForgeryToken()
                    <input asp-for="CategoryForm.TargetFieldId" type="hidden" />
                    <input asp-for="CategoryForm.ReturnModalId" type="hidden" />

                    <div class="admin-readonly-note">
                        หมวดใหม่จะถูกบันทึกไว้ใช้กับสินค้าอื่นในหน้า Items ได้ทันที
                    </div>

                    <div class="admin-form-grid">
                        <div class="admin-form-span-full">
                            <label asp-for="CategoryForm.Name" class="form-label">Category name</label>
                            <input asp-for="CategoryForm.Name" class="form-control bakery-field" placeholder="Tart" data-category-name-input />
                            <span asp-validation-for="CategoryForm.Name" class="text-danger small" data-category-validation></span>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button" data-category-submit>Create Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
