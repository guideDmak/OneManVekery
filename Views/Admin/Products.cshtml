@model AdminProductsViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products";
    ViewData["AdminDateRange"] = Model.DateRangeLabel;
    ViewData["AdminSection"] = "Products";
    var topProducts = Model.Products
        .OrderByDescending(item => item.RevenueAmount)
        .ThenByDescending(item => item.UnitsSold)
        .Take(4)
        .ToList();
    var maxTopRevenue = topProducts.FirstOrDefault()?.RevenueAmount ?? 0;
    var topProduct = topProducts.FirstOrDefault();
}

<section class="admin-metrics-grid">
    @foreach (var metric in Model.Metrics)
    {
        <article class="admin-card admin-metric-card">
            <p class="admin-card-label">@metric.Label</p>
            <div class="admin-metric-row">
                <strong>@metric.Value</strong>
                <span class="admin-metric-delta @(metric.PositiveTrend ? "is-positive" : "is-negative")">@metric.Delta</span>
            </div>
            <div class="admin-sparkline @($"is-{metric.AccentKey}")">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </div>
        </article>
    }
</section>

<section class="admin-detail-grid admin-products-detail-grid">
    <article class="admin-card admin-product-spotlight-card">
        <div class="admin-product-spotlight-copy">
            @if (topProduct is null)
            {
                <div class="admin-card-head admin-card-head-stack">
                    <div>
                        <p class="admin-page-kicker">Top Product</p>
                        <h3>ยังไม่มีข้อมูลยอดขาย</h3>
                        <span>เมื่อมีคำสั่งซื้อจริง สินค้าขายดีจะขึ้นในส่วนนี้อัตโนมัติ</span>
                    </div>
                </div>

                <div class="admin-empty-state">
                    ยังไม่มีข้อมูลยอดขายสินค้าจริงในระบบ
                </div>
            }
            else
            {
                <div class="admin-product-spotlight-head">
                    <div>
                        <p class="admin-page-kicker">Top Product</p>
                    </div>
                    <span class="admin-status-badge @($"is-{topProduct.VisibilityKey}")">@topProduct.VisibilityLabel</span>
                </div>

                <div class="admin-product-spotlight-stats admin-product-spotlight-stats-wide">
                    <div class="admin-summary-row">
                        <small>Price</small>
                        <strong>@topProduct.PriceLabel</strong>
                        <span>ราคาปัจจุบันบนหน้าร้าน</span>
                    </div>
                    <div class="admin-summary-row">
                        <small>Revenue</small>
                        <strong>@topProduct.RevenueLabel</strong>
                        <span>ยอดขายจากคำสั่งซื้อทั้งหมด</span>
                    </div>
                    <div class="admin-summary-row">
                        <small>Units Sold</small>
                        <strong>@topProduct.SalesLabel</strong>
                        <span>@topProduct.PublishedCopy</span>
                    </div>
                </div>

                <div class="admin-product-chart-head">
                    <h4>Sales Ranking</h4>
                    <span>อันดับตามรายได้รวมของออเดอร์จริง</span>
                </div>

                <div class="admin-product-top-chart">
                    @if (topProducts.Count == 0)
                    {
                        <div class="admin-empty-state">
                            ยังไม่มีข้อมูลยอดขายสินค้า
                        </div>
                    }
                    else
                    {
                        @foreach (var product in topProducts)
                        {
                            var barWidth = maxTopRevenue <= 0
                                ? 0
                                : Math.Max(18, (int)Math.Round((double)(product.RevenueAmount / maxTopRevenue) * 100));

                            <div class="admin-product-top-chart-row">
                                <div class="admin-product-top-chart-labels">
                                    <strong>@product.Name</strong>
                                    <span>@product.RevenueLabel • @product.SalesLabel</span>
                                </div>
                                <div class="admin-product-top-chart-bar-wrap">
                                    <span class="admin-product-top-chart-bar" style="width:@($"{barWidth}%")"></span>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </article>

    <article class="admin-card admin-product-status-card">
        <div class="admin-card-head admin-card-head-stack">
            <div>
                <p class="admin-page-kicker">Catalog Status</p>
                <h2>Storefront Health</h2>
                <p>ภาพรวมสินค้าที่แสดงบนหน้าร้านในตอนนี้</p>
            </div>
        </div>

        <div class="admin-product-health-grid">
            @foreach (var item in Model.SummaryItems)
            {
                <article class="admin-product-health-item @($"is-{item.AccentKey}")">
                    <small>@item.Label</small>
                    <strong>@item.Value</strong>
                    <span>@item.Detail</span>
                </article>
            }
        </div>

        <div class="admin-product-status-actions">
            <a class="admin-product-link-button" asp-action="Items">Open Items</a>
            <p>แก้ stock, SKU, ราคา และรูปสินค้าได้ที่หน้า Items</p>
        </div>
    </article>
</section>

<section class="admin-orders-section" data-admin-products>
    <article class="admin-card">
        <div class="admin-card-head admin-card-head-stack">
            <div>
                <h2>Storefront Catalog</h2>
                <p>คุมว่าสินค้าตัวไหนพร้อมขายและมองเห็นได้บนหน้าร้าน</p>
            </div>
            <a class="admin-product-link-button is-ghost" asp-action="Items">Manage Stock In Items</a>
        </div>

        @if (Model.Products.Count == 0)
        {
            <div class="admin-empty-state">
                ยังไม่มีสินค้าในระบบ เริ่มเพิ่มสินค้าที่หน้า Items ก่อน
            </div>
        }
        else
        {
            <div class="admin-products-grid">
                @foreach (var product in Model.Products)
                {
                    <article class="admin-card admin-product-showcase-card"
                             data-product-card
                             data-product-id="@product.ProductId"
                             data-product-name="@product.Name"
                             data-product-notes="@product.Notes">
                        <div class="admin-product-showcase-media">
                            <img src="@Url.Content(product.ImagePath)"
                                 alt="@product.Name"
                                 class="admin-product-showcase-image"
                                 onerror="this.src='@Url.Content("~/images/theme-cake.svg")';" />
                        </div>

                        <div class="admin-product-showcase-body">
                            <div class="admin-product-showcase-head">
                                <div>
                                    <p class="admin-item-card-code">@product.ProductCode</p>
                                    <h3>@product.Name</h3>
                                </div>
                                <span class="admin-status-badge @($"is-{product.VisibilityKey}")" data-product-visibility-badge>@product.VisibilityLabel</span>
                            </div>

                            <p class="admin-product-showcase-caption">@(string.IsNullOrWhiteSpace(product.Tagline) ? "\u00A0" : product.Tagline)</p>

                            <div class="admin-item-meta-row">
                                <span class="admin-item-meta-chip">@product.Category</span>
                                <span class="admin-item-meta-chip">@product.PriceLabel</span>
                                <span class="admin-item-meta-chip">@product.StockLabel</span>
                            </div>

                            <div class="admin-product-showcase-stats">
                                <div class="admin-summary-row">
                                    <small>Revenue</small>
                                    <strong>@product.RevenueLabel</strong>
                                    <span>ยอดขายรวมของสินค้าตัวนี้</span>
                                </div>
                                <div class="admin-summary-row">
                                    <small>Units Sold</small>
                                    <strong>@product.SalesLabel</strong>
                                    <span data-product-published-copy>@product.PublishedCopy</span>
                                </div>
                            </div>

                            <div class="admin-product-showcase-footer">
                                <form asp-action="SetProductVisibility" method="post" class="admin-product-visibility-form" data-product-visibility-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.ProductId" />
                                    <input type="hidden" name="visibilityAction" value="@(product.IsPublished ? "hide" : "publish")" data-visibility-action-input />
                                    <input type="hidden" name="visibilityNote" value="@product.Notes" data-visibility-note-input />
                                    <button type="submit"
                                            class="@(product.IsPublished ? "admin-secondary-button" : "admin-primary-button")"
                                            data-visibility-submit>
                                        @(product.IsPublished ? "Hide From Store" : "Publish To Store")
                                    </button>
                                </form>

                                <a class="admin-product-link-button is-inline" asp-action="Items">Open Items</a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </article>
</section>

<div class="modal fade admin-modal" id="productHideReasonModal" tabindex="-1" aria-labelledby="productHideReasonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Hide Product</p>
                    <h2 class="modal-title" id="productHideReasonModalLabel">Reason For Hiding</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form class="admin-item-form" data-product-hide-reason-form>
                    <div class="admin-readonly-note" data-product-hide-target>
                        ระบุเหตุผลก่อนซ่อนสินค้านี้จากหน้าร้าน
                    </div>

                    <div class="admin-form-grid">
                        <div class="admin-form-span-full">
                            <label for="ProductHideReasonInput" class="form-label">Hide reason</label>
                            <textarea id="ProductHideReasonInput"
                                      class="form-control bakery-field bakery-field-area admin-field-area"
                                      placeholder="เช่น ปรับสูตรใหม่, สินค้าหมดชั่วคราว, หยุดขายช่วงนี้"
                                      data-product-hide-reason-input></textarea>
                            <span class="text-danger small" data-product-hide-validation></span>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button" data-product-hide-confirm>Hide From Store</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
