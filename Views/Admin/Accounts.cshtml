@model AdminAccountsViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Account Management";
    ViewData["AdminDateRange"] = Model.DateRangeLabel;
    ViewData["AdminSection"] = "Accounts";
}

<section class="admin-page-banner admin-page-banner-compact">
    <div>
        <p class="admin-page-kicker">Accounts</p>
        <h2>Manage system accounts</h2>
        <span>สมัครจากหน้าเว็บจะได้แค่ User ส่วน role อื่นให้สร้างจากหน้านี้ผ่านแอดมินเท่านั้น</span>
    </div>
    <button type="button" class="admin-primary-button" data-bs-toggle="modal" data-bs-target="#addAccountModal">
        Add Account
    </button>
</section>

<section class="admin-account-summary-grid admin-item-summary-grid">
    @foreach (var item in Model.SummaryItems)
    {
        <article class="admin-card admin-account-summary-card @($"is-{item.AccentKey}")">
            <small>@item.Label</small>
            <strong>@item.Value</strong>
            <span>@item.Detail</span>
        </article>
    }
</section>

<section class="admin-account-page"
         data-admin-accounts
         data-active-modal="@Model.ActiveModal"
         data-can-change-roles="@(Model.CanChangeRoles ? "true" : "false")">
    <article class="admin-card">
        <div class="admin-card-head admin-card-head-stack">
            <div>
                <h2>Account List</h2>
                <p>เพิ่มบัญชี แก้ไข role และปิดบัญชีจากลิสต์นี้ได้โดยตรง</p>
            </div>
            <button type="button" class="admin-primary-button" data-bs-toggle="modal" data-bs-target="#addAccountModal">
                Add Account
            </button>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table admin-account-table">
                <thead>
                    <tr>
                        <th>Account</th>
                        <th>Contact</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Last Active</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in Model.Accounts)
                    {
                        <tr>
                            <td>
                                <div class="admin-order-stack">
                                    <small class="admin-account-code">@account.AccountCode</small>
                                    <strong>@account.FullName</strong>
                                    <span>@account.Role access</span>
                                </div>
                            </td>
                            <td>
                                <div class="admin-order-stack">
                                    <strong>@account.Email</strong>
                                    <span>@account.PhoneNumber</span>
                                </div>
                            </td>
                            <td>@account.Role</td>
                            <td>
                                <span class="admin-status-badge @($"is-{account.StatusKey}")">@account.Status</span>
                            </td>
                            <td>@account.LastActive</td>
                            <td class="admin-account-notes-cell">@account.Notes</td>
                            <td>
                                <div class="admin-actions admin-actions-wrap">
                                    <button type="button"
                                            class="admin-row-action-button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editAccountModal"
                                            data-account-id="@account.AccountId"
                                            data-account-code="@account.AccountCode"
                                            data-full-name="@account.FullName"
                                            data-email="@account.Email"
                                            data-phone-number="@account.PhoneNumber"
                                            data-role="@account.Role"
                                            data-status="@account.Status"
                                            data-last-active="@account.LastActive"
                                            data-notes="@account.Notes">
                                        Edit
                                    </button>

                                    <form asp-action="CloseAccount" method="post" class="admin-inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="accountId" value="@account.AccountId" />
                                        <button type="submit"
                                                class="admin-row-action-button is-danger"
                                                @(account.Status == "Closed" ? "disabled" : null)>
                                            Close Account
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>
</section>

<div class="modal fade admin-modal" id="addAccountModal" tabindex="-1" aria-labelledby="addAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Create Account</p>
                    <h2 class="modal-title" id="addAccountModalLabel">Add New Account</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="AddAccount" method="post" class="admin-item-form">
                    @Html.AntiForgeryToken()

                    <div class="admin-readonly-note">
                        Account ID จะถูกสร้างอัตโนมัติหลังบันทึก
                    </div>

                    <div class="admin-form-grid">
                        <div class="admin-form-span-full">
                            <label asp-for="AddForm.FullName" class="form-label">Full name</label>
                            <input asp-for="AddForm.FullName" class="form-control bakery-field" placeholder="Nicha Saelim" />
                            <span asp-validation-for="AddForm.FullName" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Email" class="form-label">Email</label>
                            <input asp-for="AddForm.Email" class="form-control bakery-field" placeholder="name@madbakery.com" />
                            <span asp-validation-for="AddForm.Email" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.PhoneNumber" class="form-label">Phone</label>
                            <input asp-for="AddForm.PhoneNumber" class="form-control bakery-field" placeholder="+66 8x xxx xxxx" />
                            <span asp-validation-for="AddForm.PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Role" class="form-label">Role</label>
                            <select asp-for="AddForm.Role" class="form-select bakery-field">
                                @foreach (var role in Model.AddRoleOptions)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="AddForm.Role" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Password" class="form-label">Password</label>
                            <input asp-for="AddForm.Password" class="form-control bakery-field" type="text" placeholder="อย่างน้อย 8 ตัวอักษร" />
                            <span asp-validation-for="AddForm.Password" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="AddForm.Status" class="form-label">Status</label>
                            <select asp-for="AddForm.Status" class="form-select bakery-field">
                                @foreach (var status in Model.StatusOptions)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                            <span asp-validation-for="AddForm.Status" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="AddForm.Notes" class="form-label">Notes</label>
                            <textarea asp-for="AddForm.Notes" class="form-control bakery-field bakery-field-area admin-field-area" placeholder="Short note about this account"></textarea>
                            <span asp-validation-for="AddForm.Notes" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button">Create Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade admin-modal" id="editAccountModal" tabindex="-1" aria-labelledby="editAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="admin-modal-kicker">Edit Account</p>
                    <h2 class="modal-title" id="editAccountModalLabel">Update Account Details</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form asp-action="UpdateAccount" method="post" class="admin-item-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="EditForm.AccountId" type="hidden" />

                    <div class="admin-form-grid">
                        <div>
                            <label asp-for="EditForm.AccountCode" class="form-label">Account ID</label>
                            <input asp-for="EditForm.AccountCode" class="form-control bakery-field admin-readonly-field" readonly />
                        </div>

                        <div>
                            <label asp-for="EditForm.LastActiveDisplay" class="form-label">Last active</label>
                            <input asp-for="EditForm.LastActiveDisplay" class="form-control bakery-field admin-readonly-field" readonly />
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.FullName" class="form-label">Full name</label>
                            <input asp-for="EditForm.FullName" class="form-control bakery-field" />
                            <span asp-validation-for="EditForm.FullName" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="EditForm.Email" class="form-label">Email</label>
                            <input asp-for="EditForm.Email" class="form-control bakery-field" />
                            <span asp-validation-for="EditForm.Email" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="EditForm.PhoneNumber" class="form-label">Phone</label>
                            <input asp-for="EditForm.PhoneNumber" class="form-control bakery-field" />
                            <span asp-validation-for="EditForm.PhoneNumber" class="text-danger small"></span>
                        </div>

                        @if (Model.CanChangeRoles)
                        {
                            <div>
                                <label asp-for="EditForm.Role" class="form-label">Role</label>
                                <select asp-for="EditForm.Role" class="form-select bakery-field">
                                    @foreach (var role in Model.EditRoleOptions)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="EditForm.Role" class="text-danger small"></span>
                            </div>
                        }
                        else
                        {
                            <div>
                                <label asp-for="EditForm.Role" class="form-label">Role</label>
                                <input asp-for="EditForm.Role" class="form-control bakery-field admin-readonly-field" readonly />
                                <span asp-validation-for="EditForm.Role" class="text-danger small"></span>
                            </div>
                        }

                        <div>
                            <label asp-for="EditForm.Status" class="form-label">Status</label>
                            <select asp-for="EditForm.Status" class="form-select bakery-field">
                                @foreach (var status in Model.StatusOptions)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                            <span asp-validation-for="EditForm.Status" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.Password" class="form-label">New password</label>
                            <input asp-for="EditForm.Password" class="form-control bakery-field" type="text" placeholder="เว้นว่างถ้าไม่เปลี่ยนรหัสผ่าน" />
                            <span asp-validation-for="EditForm.Password" class="text-danger small"></span>
                        </div>

                        <div class="admin-form-span-full">
                            <label asp-for="EditForm.Notes" class="form-label">Notes</label>
                            <textarea asp-for="EditForm.Notes" class="form-control bakery-field bakery-field-area admin-field-area"></textarea>
                            <span asp-validation-for="EditForm.Notes" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="button" class="admin-secondary-button" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="admin-primary-button">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
