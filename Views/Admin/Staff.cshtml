@model AdminStaffViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "จัดการ Staff";
    ViewData["AdminDateRange"] = Model.DateRangeLabel;
    ViewData["AdminSection"] = "Staff";
}

<section class="admin-page-banner admin-page-banner-compact">
    <span class="admin-pill-tag">@Model.StaffMembers.Count staff accounts</span>
</section>

<section class="admin-metrics-grid">
    @foreach (var metric in Model.Metrics)
    {
        <article class="admin-card admin-metric-card">
            <p class="admin-card-label">@metric.Label</p>
            <div class="admin-metric-row">
                <strong>@metric.Value</strong>
                <span class="admin-metric-delta @(metric.PositiveTrend ? "is-positive" : "is-negative")">@metric.Delta</span>
            </div>
            <div class="admin-sparkline @($"is-{metric.AccentKey}")">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </div>
        </article>
    }
</section>

<section class="admin-orders-section">
    <article class="admin-card">
        <div class="admin-card-head">
            <div>
                <h2>Staff List</h2>
                <p>หน้านี้แสดงเฉพาะบัญชี Staff จริงจากฐานข้อมูล และเปิดให้ Admin ดูเท่านั้น</p>
            </div>
        </div>

        @if (Model.StaffMembers.Count == 0)
        {
            <div class="admin-empty-state">ยังไม่มีบัญชี Staff ในระบบ</div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Staff ID</th>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Role</th>
                            <th>Last Active</th>
                            <th>Created</th>
                            <th>Note</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model.StaffMembers)
                        {
                            <tr>
                                <td>@staff.StaffCode</td>
                                <td>@staff.FullName</td>
                                <td>
                                    <div class="admin-order-stack">
                                        <strong>@staff.Email</strong>
                                        <span>@staff.PhoneNumber</span>
                                    </div>
                                </td>
                                <td>@staff.RoleLabel</td>
                                <td>@staff.LastActiveLabel</td>
                                <td>@staff.CreatedLabel</td>
                                <td>@staff.Notes</td>
                                <td>
                                    <span class="admin-status-badge @($"is-{staff.StatusKey}")">@staff.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>
