@model AdminCustomersViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Customers";
    ViewData["AdminDateRange"] = Model.DateRangeLabel;
    ViewData["AdminSection"] = "Customers";
}

<section class="admin-page-banner admin-page-banner-compact">
    <div>
        <p class="admin-page-kicker">Customers</p>
        <h2>Customer directory</h2>
        <span>แสดงข้อมูลลูกค้าจริงจากฐานข้อมูล พร้อมยอดซื้อและสถานะการใช้งาน</span>
    </div>
    <span class="admin-pill-tag">@Model.Customers.Count accounts</span>
</section>

<section class="admin-metrics-grid">
    @foreach (var metric in Model.Metrics)
    {
        <article class="admin-card admin-metric-card">
            <p class="admin-card-label">@metric.Label</p>
            <div class="admin-metric-row">
                <strong>@metric.Value</strong>
                <span class="admin-metric-delta @(metric.PositiveTrend ? "is-positive" : "is-negative")">@metric.Delta</span>
            </div>
            <div class="admin-sparkline @($"is-{metric.AccentKey}")">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
            </div>
        </article>
    }
</section>

<section class="admin-orders-section">
    <article class="admin-card">
        <div class="admin-card-head">
            <div>
                <h2>Customer List</h2>
                <p>ไม่มีข้อมูลตัวอย่างแล้ว หน้านี้แสดงเฉพาะลูกค้าที่มีอยู่จริงในระบบ</p>
            </div>
        </div>

        @if (Model.Customers.Count == 0)
        {
            <div class="admin-empty-state">ยังไม่มีบัญชีลูกค้าในระบบ</div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Customer ID</th>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Orders</th>
                            <th>Total Spend</th>
                            <th>Last Order</th>
                            <th>Last Active</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model.Customers)
                        {
                            <tr>
                                <td>@customer.CustomerCode</td>
                                <td>@customer.FullName</td>
                                <td>
                                    <div class="admin-order-stack">
                                        <strong>@customer.Email</strong>
                                        <span>@customer.PhoneNumber</span>
                                    </div>
                                </td>
                                <td>@customer.OrderCountLabel</td>
                                <td>@customer.TotalSpendLabel</td>
                                <td>@customer.LastOrderLabel</td>
                                <td>@customer.LastActiveLabel</td>
                                <td>
                                    <span class="admin-status-badge @($"is-{customer.StatusKey}")">@customer.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>
