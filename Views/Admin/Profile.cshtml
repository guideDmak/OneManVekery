@model AdminProfileViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Profile";
    ViewData["AdminSection"] = "Profile";
    var profileBadge = string.IsNullOrWhiteSpace(Model.FullName)
        ? "BK"
        : string.Concat(Model.FullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0])));
}

<section class="admin-page-banner">
    <div>
        <p class="admin-page-kicker">Profile</p>
        <h2>@Model.FullName</h2>
        <span>@Model.Role</span>
    </div>
    <span class="admin-pill-tag">@Model.Status</span>
</section>

<section class="admin-detail-grid">
    <article class="admin-card admin-profile-card">
        <div class="admin-profile-badge">@profileBadge</div>
        <h3>@Model.FullName</h3>
        <p>@Model.Role</p>

        <div class="admin-summary-list">
            <div class="admin-summary-row">
                <div>
                    <small>Account ID</small>
                    <strong>@Model.AccountCode</strong>
                </div>
                <span>บัญชีที่กำลังใช้งานอยู่</span>
            </div>
            <div class="admin-summary-row">
                <div>
                    <small>Email</small>
                    <strong>@Model.Email</strong>
                </div>
                <span>Main contact</span>
            </div>
            <div class="admin-summary-row">
                <div>
                    <small>Phone</small>
                    <strong>@Model.Phone</strong>
                </div>
                <span>Direct line</span>
            </div>
            <div class="admin-summary-row">
                <div>
                    <small>Last active</small>
                    <strong>@Model.LastActiveLabel</strong>
                </div>
                <span>อ้างอิงจากข้อมูลจริงในระบบ</span>
            </div>
            <div class="admin-summary-row">
                <div>
                    <small>Notes</small>
                    <strong>@Model.Notes</strong>
                </div>
                <span>หมายเหตุของบัญชีนี้</span>
            </div>
        </div>
    </article>

    <article class="admin-card">
        <div class="admin-card-head">
            <h2>System Summary</h2>
        </div>

        <div class="admin-summary-list">
            @foreach (var item in Model.SummaryItems)
            {
                <div class="admin-summary-row">
                    <div>
                        <small>@item.Label</small>
                        <strong>@item.Value</strong>
                    </div>
                    <span>@item.Detail</span>
                </div>
            }
        </div>
    </article>
</section>
