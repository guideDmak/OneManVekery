@model AdminReportsViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create New Campaign";
    ViewData["AdminSection"] = "Reports";
}

<section class="admin-page-banner admin-page-banner-compact">
    <div>
        <p class="admin-page-kicker">Reports</p>
        <h2>Create New Campaign</h2>
        <span>Rule builder style from the PDF reference</span>
    </div>
</section>

<section class="admin-campaign-grid">
    @foreach (var campaignSection in Model.Sections)
    {
        <article class="admin-card admin-campaign-card">
            <div class="admin-step-head">
                <span>@campaignSection.StepNumber</span>
                <div>
                    <h3>@campaignSection.Title</h3>
                </div>
            </div>

            <div class="admin-campaign-list">
                @foreach (var item in campaignSection.Items)
                {
                    <div class="admin-campaign-row">
                        <small>@item.Label</small>
                        <strong>@item.Value</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Detail))
                        {
                            <span>@item.Detail</span>
                        }
                    </div>
                }
            </div>
        </article>
    }

    <article class="admin-card admin-campaign-card admin-rules-card">
        <div class="admin-step-head">
            <span>4</span>
            <div>
                <h3>Create Rules</h3>
            </div>
        </div>

        <div class="admin-rules-list">
            @foreach (var rule in Model.Rules)
            {
                <article class="admin-rule-item">
                    <div class="admin-rule-pill">@rule.Metric</div>
                    <div class="admin-rule-flow">
                        <span>@rule.IntroLabel</span>
                        <strong>@rule.Comparison</strong>
                        <strong>@rule.Threshold</strong>
                        <span>@rule.MidLabel</span>
                        <strong>@rule.ActionLabel</strong>
                        <strong>@rule.ActionValue</strong>
                    </div>
                </article>
            }
        </div>

        <div class="admin-rule-actions">
            <button type="button" class="admin-secondary-button">Add Condition</button>
            <button type="button" class="admin-secondary-button">New Rule</button>
        </div>
    </article>
</section>

<section class="admin-campaign-footer">
    <button type="button" class="admin-secondary-button">Cancel</button>
    <button type="button" class="admin-primary-button">Save Campaign</button>
</section>
