@{
    var hideChrome = ViewData["HideChrome"] is bool value && value;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - One Man Vekery</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OneManVekery.styles.css" asp-append-version="true" />
</head>
<body class="@(hideChrome ? "auth-body" : string.Empty)">
    @if (!hideChrome)
    {
        <header class="site-header">
            <nav class="navbar navbar-expand-lg bakery-nav">
                <div class="container bakery-container">
                    <a class="navbar-brand bakery-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="bakery-brand-mark">OV</span>
                        <span>
                            One Man Vekery
                            <small>Sweet bakery in pink mood</small>
                        </span>
                    </a>
                    <button class="navbar-toggler bakery-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#bakeryNav" aria-controls="bakeryNav"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="bakeryNav">
                        <ul class="navbar-nav ms-auto align-items-lg-center bakery-nav-links">
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "Shop" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Shop">Shop</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "About" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="About">About</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "Contact" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn bakery-btn bakery-btn-light" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn bakery-btn bakery-btn-primary" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    @if (TempData["SiteNotice"] is string siteNotice)
    {
        <div class="container bakery-container">
            <div class="site-notice" role="status">@siteNotice</div>
        </div>
    }

    <main role="main" class="site-main @(hideChrome ? "site-main-auth" : string.Empty)">
            @RenderBody()
    </main>

    @if (!hideChrome)
    {
        <footer class="site-footer">
            <div class="container bakery-container">
                <div class="site-footer-grid">
                    <div class="site-footer-brand">
                        <p class="site-footer-title">One Man Vekery.</p>
                        <p>123 Pink Bakery Lane, Bangkok 10200, Thailand</p>
                    </div>

                    <div>
                        <p class="site-footer-label">Links</p>
                        <a asp-controller="Home" asp-action="Index">Home</a>
                        <a asp-controller="Home" asp-action="Shop">Shop</a>
                        <a asp-controller="Home" asp-action="About">About</a>
                        <a asp-controller="Home" asp-action="Contact">Contact</a>
                    </div>

                    <div>
                        <p class="site-footer-label">Help</p>
                        <span>Payment Options</span>
                        <span>Returns</span>
                        <span>Privacy Policies</span>
                    </div>

                    <div>
                        <p class="site-footer-label">Newsletter</p>
                        <form class="site-footer-newsletter">
                            <input type="email" class="form-control bakery-field" placeholder="Enter Your Email Address" />
                            <button type="button" class="btn store-inline-btn">SUBSCRIBE</button>
                        </form>
                    </div>
                </div>

                <div class="site-footer-bottom">
                    2026 One Man Vekery. All rights reserved
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
