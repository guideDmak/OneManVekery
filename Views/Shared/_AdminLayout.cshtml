@{
    var adminSection = ViewData["AdminSection"]?.ToString() ?? ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var adminDateRange = ViewData["AdminDateRange"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OneManVekery.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-brand" asp-controller="Admin" asp-action="Index">mart</a>

            <nav class="admin-nav">
                <a class="admin-nav-item @(adminSection == "Dashboard" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Index" aria-label="Dashboard" title="Dashboard">
                    <span>D</span>
                </a>
                <a class="admin-nav-item @(adminSection == "Orders" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Orders" aria-label="Orders" title="Orders">
                    <span>O</span>
                </a>
                <a class="admin-nav-item @(adminSection == "Customers" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Customers" aria-label="Customers" title="Customers">
                    <span>C</span>
                </a>
                <a class="admin-nav-item @(adminSection == "Products" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Products" aria-label="Products" title="Products">
                    <span>P</span>
                </a>
                <a class="admin-nav-item @(adminSection == "Reports" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Reports" aria-label="Reports" title="Reports">
                    <span>R</span>
                </a>
            </nav>
        </aside>

        <div class="admin-main-wrap">
            <header class="admin-topbar">
                <div>
                    <h1>@ViewData["Title"]</h1>
                </div>

                <div class="admin-topbar-actions">
                    @if (!string.IsNullOrWhiteSpace(adminDateRange))
                    {
                        <span class="admin-date-pill">@adminDateRange</span>
                    }
                    <a class="admin-back-link" asp-controller="Home" asp-action="Index">Back to store</a>
                </div>
            </header>

            <main class="admin-main">
                @RenderBody()
            </main>

            <footer class="admin-footer">
                eCommerce Platform 2020. All rights reserved
            </footer>
        </div>
    </div>
</body>
</html>
