@{
    var adminSection = ViewData["AdminSection"]?.ToString() ?? ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var adminDateRange = ViewData["AdminDateRange"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OneManVekery.styles.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-sidebar-panel">
                <div class="admin-sidebar-head">
                    <div>
                        <a class="admin-brand" asp-controller="Admin" asp-action="Index">Bakery Admin</a>
                        <p>Control Center</p>
                    </div>

                    <span class="admin-sidebar-badge">06</span>
                </div>

                <nav class="admin-nav">
                    <a class="admin-nav-item @(adminSection == "Dashboard" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Index" aria-label="Dashboard" title="Dashboard">
                        <span class="admin-nav-glyph is-dashboard" aria-hidden="true"></span>
                        <span>Dashboard</span>
                    </a>
                    <a class="admin-nav-item @(adminSection == "Orders" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Orders" aria-label="Orders" title="Orders">
                        <span class="admin-nav-glyph is-orders" aria-hidden="true"></span>
                        <span>Orders</span>
                    </a>
                    <a class="admin-nav-item @(adminSection == "Customers" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Customers" aria-label="Customers" title="Customers">
                        <span class="admin-nav-glyph is-customers" aria-hidden="true"></span>
                        <span>Customers</span>
                    </a>
                    <a class="admin-nav-item @(adminSection == "Products" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Products" aria-label="Products" title="Products">
                        <span class="admin-nav-glyph is-products" aria-hidden="true"></span>
                        <span>Products</span>
                    </a>
                    <a class="admin-nav-item @(adminSection == "Items" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Items" aria-label="Items" title="Items">
                        <span class="admin-nav-glyph is-items" aria-hidden="true"></span>
                        <span>Items</span>
                    </a>
                    <a class="admin-nav-item @(adminSection == "Accounts" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Accounts" aria-label="Accounts" title="Accounts">
                        <span class="admin-nav-glyph is-reports" aria-hidden="true"></span>
                        <span>Accounts</span>
                    </a>
                </nav>

                <div class="admin-sidebar-footer">
                    <a class="admin-sidebar-account @(adminSection == "Profile" ? "active" : string.Empty)" asp-controller="Admin" asp-action="Profile">
                        <span class="admin-sidebar-avatar">MB</span>
                        <div>
                            <strong>Mad Bakery</strong>
                            <p>Administrator</p>
                        </div>
                    </a>

                    <a class="admin-logout-link" asp-controller="Account" asp-action="Logout">Logout</a>
                </div>
            </div>
        </aside>

        <div class="admin-main-wrap">
            @if (TempData["SiteNotice"] is string siteNotice)
            {
                <div class="site-notice admin-site-notice" role="status">@siteNotice</div>
            }

            <header class="admin-topbar">
                <div>
                    <h1>@ViewData["Title"]</h1>
                </div>

                <div class="admin-topbar-actions">
                    @if (!string.IsNullOrWhiteSpace(adminDateRange))
                    {
                        <span class="admin-date-pill">@adminDateRange</span>
                    }
                    <a class="admin-back-link" asp-controller="Home" asp-action="Index">Back to store</a>
                </div>
            </header>

            <main class="admin-main">
                @RenderBody()
            </main>

            <footer class="admin-footer">
                eCommerce Platform 2020. All rights reserved
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
