@model HomeIndexViewModel

@{
    ViewData["Title"] = "หน้าแรก";
    var heroProducts = (Model.NewArrivals.Count > 0
        ? Model.NewArrivals
        : Model.Products.Take(3)).ToList();
}

<section class="store-hero">
    <div class="container bakery-container">
        <div class="store-hero-panel">
            <div class="store-hero-art">
                <span class="hero-floating hero-floating-top">อบสดใหม่</span>
                <div class="store-hero-visual-shell">
                    @if (heroProducts.Count == 0)
                    {
                        <img src="@Url.Content("~/images/hero-bakery.svg")" alt="Bakery collection" class="hero-main-image" />
                    }
                    else
                    {
                        <div id="newArrivalCarousel" class="carousel slide hero-arrival-carousel" data-bs-ride="carousel" data-bs-interval="4200">
                            <div class="carousel-indicators hero-arrival-indicators">
                                @for (var index = 0; index < heroProducts.Count; index++)
                                {
                                    <button type="button"
                                            data-bs-target="#newArrivalCarousel"
                                            data-bs-slide-to="@index"
                                            class="@(index == 0 ? "active" : string.Empty)"
                                            aria-current="@(index == 0 ? "true" : null)"
                                            aria-label="สินค้าใหม่ @(index + 1)"></button>
                                }
                            </div>

                            <div class="carousel-inner hero-arrival-inner">
                                @for (var index = 0; index < heroProducts.Count; index++)
                                {
                                    var heroProduct = heroProducts[index];
                                    <article class="carousel-item hero-arrival-slide @(index == 0 ? "active" : string.Empty)">
                                        <img src="@Url.Content(heroProduct.ImagePath)"
                                             alt="@heroProduct.Name"
                                             class="hero-main-image hero-arrival-image"
                                             onerror="this.src='@Url.Content("~/images/hero-bakery.svg")';" />
                                        <div class="hero-arrival-caption">
                                            <span>New Arrival</span>
                                            <strong>@heroProduct.Name</strong>
                                            <small>@heroProduct.Category • @heroProduct.Price.ToString("0") ฿</small>
                                        </div>
                                    </article>
                                }
                            </div>

                            <button class="carousel-control-prev hero-arrival-control" type="button" data-bs-target="#newArrivalCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">ก่อนหน้า</span>
                            </button>
                            <button class="carousel-control-next hero-arrival-control" type="button" data-bs-target="#newArrivalCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">ถัดไป</span>
                            </button>
                        </div>
                    }

                    <div class="hero-sweet-board">
                        @foreach (var heroProduct in heroProducts)
                        {
                            <article class="hero-sweet-card theme-@heroProduct.ThemeKey">
                                <strong>@heroProduct.Name</strong>
                                <span>@heroProduct.Category</span>
                            </article>
                        }
                    </div>
                </div>
            </div>

            <div class="store-hero-card">
                <span class="store-kicker">มาใหม่</span>
                <p class="store-brand-label">One Man Vekery</p>
                <h1>สั่งขนมของร้านได้ในหน้าเดียว</h1>
                <p>
                    เลือกดูสินค้าที่เปิดขายจริง เพิ่มลงตะกร้า
                    และสั่งซื้อได้ทันทีจากหน้าร้าน
                </p>
                <a class="btn store-primary-btn" asp-action="Shop">สั่งซื้อเลย</a>
            </div>
        </div>
    </div>
</section>

<section class="range-section">
    <div class="container bakery-container">
        <div class="section-heading section-heading-center">
            <p class="section-overline">หมวดขนมแนะนำ</p>
            <h2>เลือกดูตามสไตล์ที่ชอบ</h2>
            <p>ดูหมวดทั้งหมดของร้าน พร้อมเมนูขายดีในแต่ละหมวด</p>
        </div>

        <div class="range-grid">
            @foreach (var category in Model.Categories)
            {
                <article class="range-card theme-@category.ThemeKey">
                    <div class="range-visual">
                        <img src="@Url.Content(category.ImagePath)" alt="@category.FeaturedProductName" class="range-image" />
                        <span class="range-badge">@category.FeaturedProductBadge</span>
                    </div>
                    <div class="range-card-copy">
                        <span class="range-category-label">@category.Subtitle</span>
                        <h3>@category.Title</h3>
                        <p>@category.FeaturedProductDescription</p>
                    </div>
                    <div class="range-best-seller">
                        <span>ขายดีในหมวดนี้</span>
                        <strong>@category.FeaturedProductName</strong>
                        <small>@category.FeaturedProductPriceLabel · @category.FeaturedProductSalesLabel</small>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="catalog-section">
    <div class="container bakery-container">
        <div class="section-heading section-heading-center">
            <h2>สินค้าขายดี</h2>
            <p>รวม 8 เมนูที่ลูกค้าสั่งบ่อยที่สุดของร้าน</p>
        </div>

        <div class="catalog-grid">
            @foreach (var product in Model.Products)
            {
                <article class="catalog-card theme-@product.ThemeKey @(product.IsSoldOut ? "is-sold-out" : string.Empty)">
                    <div class="catalog-thumb">
                        <img src="@Url.Content(product.ImagePath)" alt="@product.Name" class="catalog-image" />
                        @if (!string.IsNullOrWhiteSpace(product.Badge))
                        {
                            <span class="catalog-badge @(product.IsSoldOut ? "catalog-badge-dark" : string.Empty)">@product.Badge</span>
                        }
                    </div>

                    <div class="catalog-body">
                        <h3>@product.Name</h3>
                        <p class="catalog-category">@product.Category</p>
                        <p class="catalog-description">@product.Description</p>

                        <div class="catalog-price">
                            <strong>@product.Price.ToString("0") ฿</strong>
                            @if (product.OriginalPrice.HasValue)
                            {
                                <span>@product.OriginalPrice.Value.ToString("0") ฿</span>
                            }
                        </div>

                        <form asp-action="AddToCart" method="post" class="store-cart-form" data-login-required-form>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.ProductId" />
                            <button type="submit" class="btn store-card-btn" @(product.IsSoldOut ? "disabled" : null)>
                                @(product.IsSoldOut ? "หมดแล้ว" : "เพิ่มลงตะกร้า")
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>

        <div class="section-action">
            <a class="btn store-outline-btn" asp-action="Shop">ดูทั้งหมด</a>
        </div>
    </div>
</section>
