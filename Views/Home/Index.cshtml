@model HomeIndexViewModel

@{
    ViewData["Title"] = "หน้าแรก";
    var heroProducts = Model.Products.Take(3).ToList();
}

<section class="store-hero">
    <div class="container bakery-container">
        <div class="store-hero-panel">
            <div class="store-hero-art">
                <span class="hero-floating hero-floating-top">อบสดใหม่</span>
                <div class="store-hero-visual-shell">
                    <img src="@Url.Content("~/images/hero-bakery.svg")" alt="Bakery collection" class="hero-main-image" />

                    <div class="hero-sweet-board">
                        @foreach (var heroProduct in heroProducts)
                        {
                            <article class="hero-sweet-card theme-@heroProduct.ThemeKey">
                                <strong>@heroProduct.Name</strong>
                                <span>@heroProduct.Category</span>
                            </article>
                        }
                    </div>
                </div>
            </div>

            <div class="store-hero-card">
                <span class="store-kicker">มาใหม่</span>
                <p class="store-brand-label">One Man Vekery</p>
                <h1>รวมขนมหวานของร้านไว้ในที่เดียว</h1>
                <p>
                    รวมสินค้าที่เปิดขายจริงจากระบบไว้ในหน้าเดียว
                    เลือกดูหมวดที่พร้อมขาย เพิ่มลงตะกร้า และสั่งซื้อได้ทันทีจากหน้าร้าน
                </p>
                <a class="btn store-primary-btn" asp-action="Shop">สั่งซื้อเลย</a>
            </div>
        </div>
    </div>
</section>

<section class="range-section">
    <div class="container bakery-container">
        <div class="section-heading section-heading-center">
            <p class="section-overline">หมวดขนมแนะนำ</p>
            <h2>เลือกดูตามสไตล์ที่ชอบ</h2>
            <p>เลือกหมวดขนมตามฟีลที่อยากได้ในวันนั้น ไม่ว่าจะเป็นของฝาก เค้กวันเกิด หรือขนมทานคู่กาแฟ</p>
        </div>

        <div class="range-grid">
            @foreach (var category in Model.Categories)
            {
                <article class="range-card theme-@category.ThemeKey">
                    <div class="range-visual">
                        <img src="@Url.Content(category.ImagePath)" alt="@category.Title" class="range-image" />
                    </div>
                    <h3>@category.Title</h3>
                    <p>@category.Subtitle</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="catalog-section">
    <div class="container bakery-container">
        <div class="section-heading section-heading-center">
            <h2>สินค้าแนะนำ</h2>
        </div>

        <div class="catalog-grid">
            @foreach (var product in Model.Products)
            {
                <article class="catalog-card theme-@product.ThemeKey @(product.IsSoldOut ? "is-sold-out" : string.Empty)">
                    <div class="catalog-thumb">
                        <img src="@Url.Content(product.ImagePath)" alt="@product.Name" class="catalog-image" />
                        @if (!string.IsNullOrWhiteSpace(product.Badge))
                        {
                            <span class="catalog-badge @(product.IsSoldOut ? "catalog-badge-dark" : string.Empty)">@product.Badge</span>
                        }
                    </div>

                    <div class="catalog-body">
                        <h3>@product.Name</h3>
                        <p class="catalog-category">@product.Category</p>
                        <p class="catalog-description">@product.Description</p>

                        <div class="catalog-price">
                            <strong>@product.Price.ToString("0") ฿</strong>
                            @if (product.OriginalPrice.HasValue)
                            {
                                <span>@product.OriginalPrice.Value.ToString("0") ฿</span>
                            }
                        </div>

                        <form asp-action="AddToCart" method="post" class="store-cart-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.ProductId" />
                            <button type="submit" class="btn store-card-btn" @(product.IsSoldOut ? "disabled" : null)>
                                @(product.IsSoldOut ? "หมดแล้ว" : "เพิ่มลงตะกร้า")
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>

        <div class="section-action">
            <a class="btn store-outline-btn" asp-action="Shop">ดูทั้งหมด</a>
        </div>
    </div>
</section>

<section class="inspiration-section">
    <div class="container bakery-container">
        <div class="inspiration-layout">
            <div class="inspiration-copy">
                <h2>เมนูที่กำลังถูกหยิบดูบนหน้าร้าน</h2>
                <p>บล็อกนี้ดึงจากสินค้าที่เปิดขายจริงในระบบ เพื่อให้เห็นเมนูเด่นของร้านในตอนนี้</p>
                <a class="btn store-primary-btn" asp-action="About">ดูเพิ่มเติม</a>
            </div>

            <div class="inspiration-gallery">
                @foreach (var inspiration in Model.Inspirations)
                {
                    <article class="inspiration-card theme-@inspiration.ThemeKey">
                        <img src="@Url.Content(inspiration.ImagePath)" alt="@inspiration.Title" class="inspiration-image" />
                        <div class="inspiration-card-copy">
                            <span>@inspiration.Number</span>
                            <p>@inspiration.Subtitle</p>
                            <h3>@inspiration.Title</h3>
                        </div>
                    </article>
                }
            </div>
        </div>
    </div>
</section>

<section class="feature-strip">
    <div class="container bakery-container">
        <div class="feature-strip-grid">
            @foreach (var feature in Model.Features)
            {
                <article class="feature-strip-item">
                    <span>@feature.IconText</span>
                    <div>
                        <h3>@feature.Title</h3>
                        <p>@feature.Description</p>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
