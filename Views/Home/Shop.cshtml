@model ShopPageViewModel

@{
    ViewData["Title"] = "สินค้า";
}

<section class="shop-toolbar">
    <div class="container bakery-container">
        <div class="shop-toolbar-shell">
            <div class="shop-toolbar-left">
                <span class="shop-toolbar-tag">กำลังเปิดขาย</span>
                <p data-results-label>พบสินค้า @Model.Products.Count รายการ</p>
            </div>
        </div>
    </div>
</section>

<section class="shop-catalog-section">
    <div class="container bakery-container">
        <div class="search-panel" data-product-search>
            <div class="search-panel-head">
                <div>
                    <p class="section-overline">ค้นหาและกรอง</p>
                    <h2>เลือกเมนูที่อยากสั่ง</h2>
                </div>
                <p class="search-panel-copy">พิมพ์ชื่อเมนูหรือเลือกหมวดสินค้าได้เลย</p>
            </div>

            <div class="search-inputs">
                <div>
                    <label for="shopSearch" class="form-label">ค้นหาสินค้า</label>
                    <input id="shopSearch" class="form-control bakery-field" type="search" placeholder="เค้ก, มาการอง, ชูครีม" data-search-input />
                </div>
                <div>
                    <label for="shopCategory" class="form-label">หมวดสินค้า</label>
                    <select id="shopCategory" class="form-select bakery-field" data-category-input>
                        <option value="all">ทุกหมวด</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
            </div>

            <div class="catalog-grid" data-product-list>
                @foreach (var product in Model.Products)
                {
                    <article class="catalog-card theme-@product.ThemeKey @(product.IsSoldOut ? "is-sold-out" : string.Empty)"
                             data-product-card
                             data-name="@($"{product.Name} {product.Description}".ToLowerInvariant())"
                             data-category="@product.Category">
                        <div class="catalog-thumb">
                            <img src="@Url.Content(product.ImagePath)" alt="@product.Name" class="catalog-image" />
                            @if (!string.IsNullOrWhiteSpace(product.Badge))
                            {
                                <span class="catalog-badge @(product.IsSoldOut ? "catalog-badge-dark" : string.Empty)">@product.Badge</span>
                            }
                        </div>

                        <div class="catalog-body">
                            <h3>@product.Name</h3>
                            <p class="catalog-category">@product.Category</p>
                            <p class="catalog-description">@product.Description</p>

                            <div class="catalog-price">
                                <strong>@product.Price.ToString("0") ฿</strong>
                                @if (product.OriginalPrice.HasValue)
                                {
                                    <span>@product.OriginalPrice.Value.ToString("0") ฿</span>
                                }
                            </div>

                            <form asp-action="AddToCart" method="post" class="store-cart-form" data-login-required-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.ProductId" />
                                <button type="submit" class="btn store-card-btn" @(product.IsSoldOut ? "disabled" : null)>
                                    @(product.IsSoldOut ? "หมดแล้ว" : "เพิ่มลงตะกร้า")
                                </button>
                            </form>
                        </div>
                    </article>
                }
            </div>

            <div class="empty-products d-none" data-empty-state>ไม่พบสินค้าที่ตรงกับคำค้นหาในตอนนี้</div>
        </div>
    </div>
</section>
