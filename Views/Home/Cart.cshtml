@model CartPageViewModel

@{
    ViewData["Title"] = "ตะกร้า";
}

<section class="cart-page-section">
    <div class="container bakery-container">
        @if (!Model.HasItems)
        {
            <article class="cart-empty-state">
                <div>
                    <p class="section-overline">ตะกร้าของคุณ</p>
                    <h2>ตะกร้ายังว่างอยู่</h2>
                    <p>เลือกสินค้าจากหน้าร้านแล้วกลับมาสรุปยอดได้ที่หน้านี้</p>
                </div>
                <a class="btn store-primary-btn" asp-action="Shop">เลือกสินค้าต่อ</a>
            </article>
        }
        else
        {
            <div class="cart-layout">
                <article class="cart-list-card">
                    <div class="cart-list-head">
                        <div>
                            <p class="section-overline">ตะกร้าของคุณ</p>
                            <h2>สินค้า @Model.ItemCount ชิ้น</h2>
                        </div>
                        <span class="cart-list-note">ส่งฟรีอัตโนมัติเมื่อยอดสินค้าครบ 100 ฿ ขึ้นไป</span>
                    </div>

                    <div class="cart-item-list">
                        @foreach (var item in Model.Items)
                        {
                            <article class="cart-item-card">
                                <div class="cart-item-media">
                                    <img src="@Url.Content(item.ImagePath)" alt="@item.Name" class="cart-item-image" />
                                </div>

                                <div class="cart-item-body">
                                    <div class="cart-item-head">
                                        <div>
                                            <p class="cart-item-category">@item.Category</p>
                                            <h3>@item.Name</h3>
                                        </div>
                                        @if (item.IsSoldOut)
                                        {
                                            <span class="cart-item-flag">หมดแล้ว</span>
                                        }
                                    </div>

                                    <p class="cart-item-description">@item.Description</p>

                                    <div class="cart-item-footer">
                                        <div class="cart-item-pricing">
                                            <span>ราคาต่อชิ้น</span>
                                            <strong>@item.UnitPriceLabel</strong>
                                        </div>

                                        <div class="cart-quantity-control">
                                            <form asp-action="ChangeCartQuantity" method="post" class="admin-inline-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="delta" value="-1" />
                                                <button type="submit" class="cart-qty-button">-</button>
                                            </form>

                                            <span>@item.Quantity</span>

                                            <form asp-action="ChangeCartQuantity" method="post" class="admin-inline-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="delta" value="1" />
                                                <button type="submit" class="cart-qty-button is-plus">+</button>
                                            </form>
                                        </div>

                                        <div class="cart-item-pricing cart-item-total">
                                            <span>รวมรายการนี้</span>
                                            <strong>@item.LineTotalLabel</strong>
                                        </div>

                                        <form asp-action="RemoveFromCart" method="post" class="cart-remove-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn store-outline-btn cart-remove-button">ลบออก</button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </article>

                <aside class="cart-summary-card">
                    <div class="cart-summary-head">
                        <p class="section-overline">ชำระเงิน</p>
                        <h2>ยืนยันข้อมูลการสั่งซื้อ</h2>
                    </div>

                    <div class="cart-summary-totals">
                        <div class="cart-summary-row">
                            <span>ค่าสินค้า</span>
                            <strong>@Model.Subtotal.ToString("0.##") ฿</strong>
                        </div>
                        <div class="cart-summary-row">
                            <span>ค่าส่ง</span>
                            <strong>@Model.DeliveryFee.ToString("0.##") ฿</strong>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="cart-summary-row cart-summary-row-discount">
                                <span>ส่วนลดสินค้า</span>
                                <strong>-@Model.DiscountAmount.ToString("0.##") ฿</strong>
                            </div>
                        }
                        @if (Model.ShippingDiscountAmount > 0)
                        {
                            <div class="cart-summary-row cart-summary-row-discount">
                                <span>ส่วนลดค่าส่ง</span>
                                <strong>-@Model.ShippingDiscountAmount.ToString("0.##") ฿</strong>
                            </div>
                        }
                        <div class="cart-summary-row is-total">
                            <span>รวมทั้งหมด</span>
                            <strong>@Model.Total.ToString("0.##") ฿</strong>
                        </div>
                    </div>

                    @if (Model.AppliedBenefits.Count > 0)
                    {
                        <div class="cart-benefit-list">
                            @foreach (var benefit in Model.AppliedBenefits)
                            {
                                <article class="cart-benefit-item is-@benefit.Tone">
                                    <div>
                                        <strong>@benefit.Title</strong>
                                        <span>@benefit.Description</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(benefit.ValueLabel))
                                    {
                                        <em>@benefit.ValueLabel</em>
                                    }
                                </article>
                            }
                        </div>
                    }

                    <form asp-action="Checkout" method="post" class="cart-checkout-form" data-checkout-form>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <div class="cart-promo-panel">
                            <div class="cart-promo-copy">
                                <div>
                                    <p class="section-overline">โค้ดส่วนลด</p>
                                    <h3>มีโค้ดค่อยใส่ก่อนยืนยันออเดอร์</h3>
                                </div>
                                @if (Model.HasAppliedPromotion)
                                {
                                    <span class="cart-promo-badge">@Model.AppliedPromoCode</span>
                                }
                            </div>

                            <div class="cart-promo-entry">
                                <input asp-for="Checkout.PromoCode" class="form-control bakery-field" placeholder="เช่น WELCOME10" data-checkout-promo-field />
                                <button type="submit" class="btn store-outline-btn cart-promo-button" asp-action="ApplyPromoCode" name="checkoutPreviewAction" value="promo" formnovalidate data-checkout-preview-submit>ใช้โค้ด</button>
                            </div>
                            <small class="cart-promo-helper">ไม่มีโค้ดสามารถเว้นว่างและยืนยันการชำระเงินได้เลย</small>
                            <span asp-validation-for="Checkout.PromoCode" class="text-danger small"></span>

                            @if (Model.HasPromoMessage)
                            {
                                <div class="cart-promo-status is-@Model.PromoMessageState">
                                    <strong>@(Model.HasAppliedPromotion ? Model.AppliedPromoTitle : "ตรวจสอบโค้ดส่วนลด")</strong>
                                    <span>@Model.PromoMessage</span>
                                </div>
                            }
                        </div>

                        <div class="cart-loyalty-panel">
                            <div class="cart-loyalty-head">
                                <div>
                                    <p class="section-overline">พอยต์สะสม</p>
                                    <h3>@Model.CurrentPoints P</h3>
                                </div>
                                <span class="cart-loyalty-projection">หลังสั่งซื้อ @Model.ProjectedPointsBalance P</span>
                            </div>

                            <div class="cart-loyalty-grid">
                                <div class="cart-loyalty-stat">
                                    <span>ได้รับเพิ่ม</span>
                                    <strong>+@Model.PointsEarned P</strong>
                                </div>
                                <div class="cart-loyalty-stat">
                                    <span>ใช้แลก</span>
                                    <strong>-@Model.PointsRedeemed P</strong>
                                </div>
                            </div>

                            <div class="cart-point-redeem-box">
                                <div>
                                    <label asp-for="Checkout.PointsToRedeem" class="form-label">ใช้พอยต์ลดราคา</label>
                                    <small>เรต @Model.PointDiscountRateLabel ใช้ได้สูงสุด @Model.MaxPointDiscountRedeem P กรอกแล้วกดอัปเดตยอด</small>
                                </div>
                                <div class="cart-point-redeem-entry">
                                    <input asp-for="Checkout.PointsToRedeem"
                                           class="form-control bakery-field"
                                           type="number"
                                           min="0"
                                           max="@Model.MaxPointDiscountRedeem"
                                           step="1"
                                           placeholder="0"
                                           data-checkout-points-field />
                                    <button type="submit" class="btn store-outline-btn cart-promo-button" asp-action="ApplyPromoCode" name="checkoutPreviewAction" value="points" formnovalidate data-checkout-preview-submit>อัปเดตยอด</button>
                                </div>
                                @if (Model.PointsDiscountAmount > 0)
                                {
                                    <p class="cart-loyalty-note">ใช้พอยต์ลดราคาแล้ว @Model.PointsDiscountAmount.ToString("0.##") ฿</p>
                                }
                                <span asp-validation-for="Checkout.PointsToRedeem" class="text-danger small"></span>
                            </div>

                            @if (Model.RewardPointCost > 0 && Model.CanRedeemFreeItem)
                            {
                                <label class="cart-reward-toggle">
                                    <input asp-for="Checkout.UsePointsReward" type="checkbox" />
                                    <div>
                                        <strong>ใช้ @Model.RewardPointCost พอยต์แลก @Model.RewardProductName ฟรี @Model.RewardQty ชิ้น</strong>
                                        <span>ระบบจะคำนวณจากสินค้าของรางวัลที่กำหนดไว้ในโปรโมชันจริงของร้าน</span>
                                    </div>
                                </label>
                                <span asp-validation-for="Checkout.UsePointsReward" class="text-danger small"></span>
                            }
                            else if (Model.RewardPointCost > 0)
                            {
                                <p class="cart-loyalty-note">สะสมอีก @Model.PointsNeededForFreeItem P เพื่อแลก @Model.RewardProductName ฟรี @Model.RewardQty ชิ้น</p>
                            }
                        </div>

                        <div class="cart-payment-options">
                            @foreach (var option in Model.PaymentOptions)
                            {
                                <label class="cart-payment-option @(Model.Checkout.PaymentMethod == option.Code ? "is-selected" : string.Empty)" data-payment-option-label="@option.Label" data-payment-option-description="@option.Description">
                                    <input asp-for="Checkout.PaymentMethod" type="radio" value="@option.Code" data-checkout-payment-field />
                                    <div>
                                        <strong>@option.Label</strong>
                                        <span>@option.Description</span>
                                    </div>
                                </label>
                            }
                            <span asp-validation-for="Checkout.PaymentMethod" class="text-danger small"></span>
                        </div>

                        <div class="cart-form-grid">
                            <div class="cart-form-span-full">
                                <label asp-for="Checkout.CustomerName" class="form-label">ชื่อผู้รับ</label>
                                <input asp-for="Checkout.CustomerName" class="form-control bakery-field" placeholder="ชื่อ-นามสกุล" data-checkout-customer-field />
                                <span asp-validation-for="Checkout.CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="cart-form-span-full">
                                <label asp-for="Checkout.PhoneNumber" class="form-label">เบอร์โทร</label>
                                <input asp-for="Checkout.PhoneNumber" class="form-control bakery-field" placeholder="089-000-1122" data-checkout-phone-field />
                                <span asp-validation-for="Checkout.PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="cart-form-span-full">
                                <label asp-for="Checkout.DeliveryAddress" class="form-label">ที่อยู่จัดส่ง</label>
                                <textarea asp-for="Checkout.DeliveryAddress" class="form-control bakery-field bakery-field-area cart-address-field" placeholder="บ้านเลขที่ ถนน แขวง เขต จังหวัด" data-checkout-address-field></textarea>
                                <span asp-validation-for="Checkout.DeliveryAddress" class="text-danger small"></span>
                            </div>

                            <div class="cart-form-span-full">
                                <label asp-for="Checkout.Notes" class="form-label">หมายเหตุ</label>
                                <textarea asp-for="Checkout.Notes" class="form-control bakery-field bakery-field-area cart-note-field" placeholder="เวลาที่สะดวกรับ, เทียนวันเกิด, การ์ดอวยพร ฯลฯ" data-checkout-notes-field></textarea>
                            </div>
                        </div>

                        <button type="submit" class="btn store-primary-btn cart-checkout-button" data-checkout-submit>ยืนยันการชำระเงิน</button>
                    </form>
                </aside>
            </div>
        }
    </div>
</section>

@if (Model.HasItems)
{
    <div class="modal fade checkout-review-modal" id="checkoutReviewModal" tabindex="-1" aria-labelledby="checkoutReviewTitle" aria-hidden="true" data-checkout-review-modal>
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg checkout-review-dialog">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="checkout-review-head">
                        <p class="section-overline">ตรวจสอบคำสั่งซื้อ</p>
                        <h2 id="checkoutReviewTitle">ยืนยันรายละเอียดก่อนชำระเงิน</h2>
                        <p>ตรวจสอบข้อมูลให้ถูกต้องก่อนสร้างออเดอร์ ถ้าต้องแก้ไขให้กด “ไม่” เพื่อกลับไปแก้ข้อมูล</p>
                    </div>

                    <div class="checkout-review-grid">
                        <section class="checkout-review-section">
                            <h3>รายการสินค้า</h3>
                            <div class="checkout-review-lines">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="checkout-review-line">
                                        <span>@item.Name <small>x @item.Quantity</small></span>
                                        <strong>@item.LineTotalLabel</strong>
                                    </div>
                                }
                            </div>
                        </section>

                        <section class="checkout-review-section">
                            <h3>ยอดชำระ</h3>
                            <div class="checkout-review-lines">
                                <div class="checkout-review-line">
                                    <span>ค่าสินค้า</span>
                                    <strong>@Model.Subtotal.ToString("0.##") ฿</strong>
                                </div>
                                <div class="checkout-review-line">
                                    <span>ค่าส่ง</span>
                                    <strong>@Model.DeliveryFee.ToString("0.##") ฿</strong>
                                </div>
                                @if (Model.DiscountAmount > 0)
                                {
                                    <div class="checkout-review-line is-discount">
                                        <span>ส่วนลดสินค้า</span>
                                        <strong>-@Model.DiscountAmount.ToString("0.##") ฿</strong>
                                    </div>
                                }
                                @if (Model.ShippingDiscountAmount > 0)
                                {
                                    <div class="checkout-review-line is-discount">
                                        <span>ส่วนลดค่าส่ง</span>
                                        <strong>-@Model.ShippingDiscountAmount.ToString("0.##") ฿</strong>
                                    </div>
                                }
                                <div class="checkout-review-line is-total">
                                    <span>รวมทั้งหมด</span>
                                    <strong>@Model.Total.ToString("0.##") ฿</strong>
                                </div>
                            </div>
                        </section>

                        <section class="checkout-review-section">
                            <h3>โปรโมชันและพอยต์</h3>
                            <div class="checkout-review-lines">
                                <div class="checkout-review-line">
                                    <span>โค้ดส่วนลด</span>
                                    <strong data-checkout-review-promo>@(Model.HasAppliedPromotion ? Model.AppliedPromoCode : "ไม่มี")</strong>
                                </div>
                                <div class="checkout-review-line">
                                    <span>แลกพอยต์</span>
                                    <strong data-checkout-review-reward>@(Model.Checkout.UsePointsReward ? "ใช้พอยต์แลกของรางวัล" : "ไม่ใช้")</strong>
                                </div>
                                <div class="checkout-review-line">
                                    <span>พอยต์ลดราคา</span>
                                    <strong data-checkout-review-points>@(Model.Checkout.PointsToRedeem > 0 ? $"{Model.Checkout.PointsToRedeem} P" : "ไม่ใช้")</strong>
                                </div>
                                <div class="checkout-review-line">
                                    <span>ได้รับพอยต์</span>
                                    <strong>+@Model.PointsEarned P</strong>
                                </div>
                                <div class="checkout-review-line">
                                    <span>พอยต์หลังสั่งซื้อ</span>
                                    <strong>@Model.ProjectedPointsBalance P</strong>
                                </div>
                            </div>
                            @if (Model.AppliedBenefits.Count > 0)
                            {
                                <div class="checkout-review-benefits">
                                    @foreach (var benefit in Model.AppliedBenefits)
                                    {
                                        <div>
                                            <strong>@benefit.Title</strong>
                                            <span>@benefit.Description</span>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <section class="checkout-review-section">
                            <h3>ข้อมูลผู้รับ</h3>
                            <dl class="checkout-review-details">
                                <div>
                                    <dt>ชื่อผู้รับ</dt>
                                    <dd data-checkout-review-customer>ไม่ระบุ</dd>
                                </div>
                                <div>
                                    <dt>เบอร์โทร</dt>
                                    <dd data-checkout-review-phone>ไม่ระบุ</dd>
                                </div>
                                <div>
                                    <dt>วิธีชำระเงิน</dt>
                                    <dd data-checkout-review-payment>ไม่ระบุ</dd>
                                </div>
                                <div>
                                    <dt>ที่อยู่จัดส่ง</dt>
                                    <dd data-checkout-review-address>ไม่ระบุ</dd>
                                </div>
                                <div>
                                    <dt>หมายเหตุ</dt>
                                    <dd data-checkout-review-notes>ไม่มี</dd>
                                </div>
                            </dl>
                        </section>
                    </div>

                    <div class="checkout-review-actions">
                        <button type="button" class="btn store-outline-btn checkout-review-secondary" data-bs-dismiss="modal">ไม่</button>
                        <button type="button" class="btn store-primary-btn checkout-review-primary" data-checkout-review-confirm>ใช่</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
