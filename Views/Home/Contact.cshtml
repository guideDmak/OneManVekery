@model ContactPageViewModel

@{
    ViewData["Title"] = "ติดต่อ";
}

<section class="contact-page-section">
    <div class="container bakery-container">
        <div class="section-heading section-heading-center contact-heading">
            <h2>@Model.HeadingTitle</h2>
        </div>

        <div class="contact-page-grid">
            <div class="contact-info-stack">
                @foreach (var card in Model.ContactCards)
                {
                    <article class="contact-info-card">
                        <span class="contact-info-icon">@card.IconText</span>
                        <div>
                            <h3>@card.Title</h3>
                            <p>@card.LineOne</p>
                            <p>@card.LineTwo</p>
                        </div>
                    </article>
                }
            </div>

            <div class="contact-form-card">
                <form asp-action="Contact" method="post" class="contact-form-grid">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small form-span-full"></div>

                    <div>
                        <label asp-for="Form.Name" class="form-label">ชื่อของคุณ</label>
                        <input asp-for="Form.Name" class="form-control bakery-field" placeholder="เช่น อัญชลี" />
                        <span asp-validation-for="Form.Name" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="Form.PhoneNumber" class="form-label">เบอร์โทร</label>
                        <input asp-for="Form.PhoneNumber" class="form-control bakery-field" placeholder="089-000-1122" />
                        <span asp-validation-for="Form.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="form-span-full">
                        <label asp-for="Form.Email" class="form-label">อีเมล</label>
                        <input asp-for="Form.Email" class="form-control bakery-field" placeholder="abc@def.com" />
                        <span asp-validation-for="Form.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-span-full">
                        <label asp-for="Form.Subject" class="form-label">หัวข้อ</label>
                        <input asp-for="Form.Subject" class="form-control bakery-field" placeholder="ไม่กรอกก็ได้" />
                    </div>

                    <div class="form-span-full">
                        <label asp-for="Form.Message" class="form-label">ข้อความ</label>
                        <textarea asp-for="Form.Message" class="form-control bakery-field bakery-field-area" placeholder="ต้องการสอบถามเรื่อง..."></textarea>
                        <span asp-validation-for="Form.Message" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn store-primary-btn form-span-full contact-submit-btn">ส่งข้อความ</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
