@model RegisterViewModel

@{
    ViewData["Title"] = "สมัครสมาชิก";
    ViewData["HideChrome"] = true;
}

<section class="auth-section">
    <div class="container auth-container">
        <div class="auth-shell auth-shell-register">
            <div class="auth-panel auth-panel-form">
                <div class="auth-form-wrap">
                    <h1>สร้างบัญชีผู้ใช้</h1>
                    <p class="auth-copy">
                        สมัครสมาชิกเพื่อบันทึกเมนูโปรดและสั่งขนมต่อได้สะดวกขึ้น
                        บัญชีที่สมัครจากหน้านี้จะเป็นบัญชีผู้ใช้งานทั่วไปเท่านั้น
                        และไม่สามารถใช้เข้าสู่หน้าหลังบ้านได้
                    </p>

                    <form asp-action="Register" method="post" class="auth-form auth-form-register">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small auth-form-span"></div>

                        <div class="auth-field-wrap">
                            <label asp-for="FullName" class="form-label">ชื่อ - นามสกุล</label>
                            <input asp-for="FullName" class="form-control bakery-field auth-field" placeholder="ชื่อ - นามสกุล" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="auth-field-wrap">
                            <label asp-for="Email" class="form-label">อีเมล</label>
                            <input asp-for="Email" class="form-control bakery-field auth-field" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="auth-field-wrap">
                            <label asp-for="PhoneNumber" class="form-label">เบอร์โทร</label>
                            <input asp-for="PhoneNumber" class="form-control bakery-field auth-field" placeholder="08x-xxx-xxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="auth-field-wrap">
                            <label asp-for="Password" class="form-label">รหัสผ่าน</label>
                            <input asp-for="Password" type="text" class="form-control bakery-field auth-field" placeholder="อย่างน้อย 8 ตัวอักษร" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="auth-field-wrap">
                            <label asp-for="ConfirmPassword" class="form-label">ยืนยันรหัสผ่าน</label>
                            <input asp-for="ConfirmPassword" type="text" class="form-control bakery-field auth-field" placeholder="กรอกรหัสผ่านอีกครั้ง" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn auth-submit w-100 auth-form-span">สร้างบัญชี</button>
                    </form>

                    <p class="auth-switch auth-switch-center auth-switch-register">
                        มีบัญชีอยู่แล้ว?
                        <a asp-action="Login">ไปหน้าเข้าสู่ระบบ</a>
                    </p>
                </div>
            </div>

            <div class="auth-panel auth-panel-image">
                <div class="auth-reference-image" aria-hidden="true"></div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
